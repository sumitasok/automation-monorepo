# Secrets — never commit
.env
.env.*
!.env.example
data/secrets/
*.key
*.pem

# Scratch / drop zone
data/inbox/*
!data/inbox/.gitkeep

# Per-run logs (history lives in SQLite, raw logs are local)
logs/
*.log

# Language cruft
__pycache__/
*.pyc
.venv/
venv/
node_modules/
dist/
*.exe
*.out

# OS cruft
.DS_Store
Thumbs.db

# SQLite transaction journals
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm
