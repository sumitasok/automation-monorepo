# Secrets — never commit
.env
.env.*
!.env.example
data/secrets/
*.key
*.pem

# Scratch / drop zone
data/inbox/*
!data/inbox/.gitkeep

# Per-run logs (history lives in SQLite, raw logs are local)
logs/
*.log

# Language cruft
__pycache__/
*.pyc
.venv/
venv/
node_modules/
dist/
*.exe
*.out

# OS cruft
.DS_Store
Thumbs.db

# Machine-local state DBs — NOT versioned. Run history, caches, and per-machine
# state are specific to the machine that produced them; committing them causes
# merge conflicts and history bloat. Data meant to sync lives as diffable
# exports (JSONL/CSV/YAML) — see docs/adr/0005. Force-add only if you have
# deliberately chosen to share a specific DB.
data/state/*.sqlite
data/state/*.db
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm
