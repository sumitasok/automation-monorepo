#!/usr/bin/env python3
"""auto — the automation-monorepo CLI.

Every script is a "job" folder under jobs/ with a manifest.yaml. This tool reads
those manifests and does everything else: discover, run, scaffold, schedule,
document, and health-check.

Usage:
  auto list [--json]
  auto search <term>
  auto run <id> [-- extra args passed to the job]
  auto new
  auto catalog
  auto schedule sync [--dry-run]
  auto log "<message>"
  auto doctor
  auto bootstrap
"""
from __future__ import annotations
import argparse, os, platform, re, socket, subprocess, sys, textwrap, datetime, shutil
from pathlib import Path

REPO = Path(__file__).resolve().parent.parent
JOBS = REPO / "jobs"
DATA = REPO / "data"
GEN = REPO / "schedules" / "generated"
WORKLOG = REPO / "docs" / "worklog"

try:
    import yaml  # PyYAML
except ImportError:
    sys.exit("PyYAML is required.  Install it:  pip install pyyaml  (or: pip install --break-system-packages pyyaml)")


# ---------- helpers ----------------------------------------------------------
def load_yaml(p: Path) -> dict:
    with open(p) as f:
        return yaml.safe_load(f) or {}

def find_manifests() -> list[Path]:
    return sorted(p for p in JOBS.rglob("manifest.yaml") if "_template" not in p.parts)

def load_jobs() -> list[dict]:
    jobs = []
    for mp in find_manifests():
        try:
            m = load_yaml(mp)
        except Exception as e:
            print(f"! bad manifest {mp}: {e}", file=sys.stderr); continue
        m["_dir"] = mp.parent
        jobs.append(m)
    return jobs

def get_job(job_id: str) -> dict:
    for j in load_jobs():
        if j.get("id") == job_id:
            return j
    sys.exit(f"no job with id '{job_id}'  (try: auto list)")

def this_os() -> str:
    s = platform.system().lower()
    return {"darwin": "macos", "windows": "windows"}.get(s, "linux")

def machines() -> list[dict]:
    mf = REPO / "machines.yaml"
    return load_yaml(mf).get("machines", []) if mf.exists() else []

def current_machine() -> dict | None:
    host = os.environ.get("AUTO_MACHINE_ID") or socket.gethostname()
    for m in machines():
        if host in (m.get("id"), m.get("hostname")):
            return m
    return None

def job_runs_here(j: dict, mach: dict | None) -> bool:
    ro = j.get("runs_on", {}) or {}
    oses = ro.get("os", ["macos", "linux", "windows"])
    if this_os() not in oses:
        return False
    want = ro.get("machines", ["any"])
    if "any" in want:
        return True
    return bool(mach and mach.get("id") in want)


# ---------- commands ---------------------------------------------------------
def cmd_list(args):
    jobs = load_jobs()
    if getattr(args, "json", False):
        import json
        print(json.dumps([{k: v for k, v in j.items() if k != "_dir"} for j in jobs], indent=2, default=str))
        return
    if not jobs:
        print("no jobs yet — create one with:  auto new"); return
    w = max((len(j.get("id", "")) for j in jobs), default=2)
    for j in jobs:
        sch = (j.get("schedule") or {})
        when = sch.get("cron") if sch.get("enabled") else "(manual)"
        print(f"{j.get('id',''):<{w}}  {j.get('language',''):<6}  {when or '(none)':<12}  {j.get('name','')}")

def cmd_search(args):
    term = args.term.lower()
    for j in load_jobs():
        hay = " ".join(str(j.get(k, "")) for k in ("id", "name", "description", "category")) + " " + " ".join(j.get("tags", []))
        if term in hay.lower():
            print(f"{j.get('id')}  —  {j.get('name')}  [{j.get('category')}]")

def cmd_run(args):
    j = get_job(args.id)
    d = j["_dir"]
    entry = d / j.get("entrypoint", "")
    if not entry.exists():
        sys.exit(f"entrypoint not found: {entry}")
    lang = j.get("language", "bash")
    runner = {"python": [sys.executable], "node": ["node"], "bash": ["bash"], "go": ["go", "run"]}.get(lang, ["bash"])
    cmd = runner + [str(entry)] + args.extra
    env = {**os.environ, "AUTO_DATA_DIR": str(DATA), "AUTO_REPO": str(REPO), "AUTO_JOB_ID": j["id"]}
    timeout = (j.get("runtime") or {}).get("timeout_seconds", 600)
    start = datetime.datetime.now()
    print(f">> running {j['id']}: {' '.join(cmd)}")
    try:
        rc = subprocess.run(cmd, env=env, timeout=timeout).returncode
    except subprocess.TimeoutExpired:
        rc = 124; print(f"!! timed out after {timeout}s")
    dur = (datetime.datetime.now() - start).total_seconds()
    _record_run(j["id"], rc, dur)
    print(f"<< {j['id']} exited {rc} in {dur:.1f}s")
    sys.exit(rc)

def _record_run(job_id: str, rc: int, dur: float):
    try:
        import sqlite3
        db = DATA / "state" / "runs.sqlite"
        db.parent.mkdir(parents=True, exist_ok=True)
        c = sqlite3.connect(db)
        c.execute("CREATE TABLE IF NOT EXISTS runs(ts TEXT, job TEXT, host TEXT, rc INTEGER, dur REAL)")
        c.execute("INSERT INTO runs VALUES (?,?,?,?,?)",
                  (datetime.datetime.utcnow().isoformat(), job_id, socket.gethostname(), rc, dur))
        c.commit(); c.close()
    except Exception as e:
        print(f"(could not record run history: {e})", file=sys.stderr)

def cmd_new(args):
    print("New job scaffold.")
    jid = input("  id (kebab-case): ").strip()
    if not re.fullmatch(r"[a-z0-9][a-z0-9-]*", jid or ""):
        sys.exit("id must be kebab-case")
    cat = input("  category [uncategorized]: ").strip() or "uncategorized"
    name = input("  name: ").strip() or jid
    lang = input("  language [python/bash/node/go]: ").strip() or "python"
    dest = JOBS / cat / jid
    if dest.exists():
        sys.exit(f"{dest} already exists")
    shutil.copytree(JOBS / "_template", dest)
    ext = {"python": "py", "bash": "sh", "node": "js", "go": "go"}.get(lang, "sh")
    entry = f"main.{ext}"
    (dest / entry).write_text(f"# {name}\n" if lang != "bash" else "#!/usr/bin/env bash\nset -euo pipefail\necho hi\n")
    # fill manifest
    mp = dest / "manifest.yaml"
    m = load_yaml(mp)
    m.update({"id": jid, "name": name, "category": cat, "language": lang, "entrypoint": entry})
    with open(mp, "w") as f:
        yaml.safe_dump(m, f, sort_keys=False)
    print(f"created {dest}\n  edit the manifest + {entry}, then:  auto run {jid}")

def cmd_catalog(args):
    jobs = load_jobs()
    lines = ["# Catalog", "", "_Auto-generated by `auto catalog`. Do not edit by hand._", "",
             f"{len(jobs)} job(s).", "",
             "| id | name | lang | schedule | machines | category |",
             "|----|------|------|----------|----------|----------|"]
    for j in sorted(jobs, key=lambda x: (x.get("category", ""), x.get("id", ""))):
        sch = j.get("schedule") or {}
        when = f"`{sch.get('cron')}`" if sch.get("enabled") and sch.get("cron") else "manual"
        mc = ", ".join((j.get("runs_on") or {}).get("machines", ["any"]))
        rel = j["_dir"].relative_to(REPO)
        lines.append(f"| [{j.get('id')}]({rel}) | {j.get('name','')} | {j.get('language','')} | {when} | {mc} | {j.get('category','')} |")
    (REPO / "CATALOG.md").write_text("\n".join(lines) + "\n")
    print(f"wrote CATALOG.md ({len(jobs)} jobs)")

def cmd_log(args):
    WORKLOG.mkdir(parents=True, exist_ok=True)
    today = datetime.date.today().isoformat()
    f = WORKLOG / f"{today}.md"
    if not f.exists():
        f.write_text(f"# Worklog — {today}\n\n")
    ts = datetime.datetime.now().strftime("%H:%M")
    with open(f, "a") as fh:
        fh.write(f"- {ts} — {args.message}\n")
    print(f"logged to {f.relative_to(REPO)}")

def cmd_doctor(args):
    ok = True
    ids = {}
    for mp in find_manifests():
        try:
            m = load_yaml(mp)
        except Exception as e:
            print(f"FAIL {mp}: unreadable ({e})"); ok = False; continue
        for field in ("id", "name", "language", "entrypoint"):
            if not m.get(field):
                print(f"FAIL {mp}: missing '{field}'"); ok = False
        jid = m.get("id")
        if jid in ids:
            print(f"FAIL duplicate id '{jid}' in {mp} and {ids[jid]}"); ok = False
        ids[jid] = mp
        entry = mp.parent / m.get("entrypoint", "")
        if m.get("entrypoint") and not entry.exists():
            print(f"FAIL {jid}: entrypoint missing ({entry})"); ok = False
    print("OK — all manifests valid" if ok else "doctor found problems")
    sys.exit(0 if ok else 1)

def cmd_bootstrap(args):
    print(f"machine os = {this_os()}, hostname = {socket.gethostname()}")
    m = current_machine()
    print(f"registered as: {m['id']}" if m else "NOT in machines.yaml — add this host there.")
    if shutil.which("git"):
        subprocess.run(["git", "lfs", "install"], cwd=REPO)
    for tool in ("python3", "node", "go", "sqlite3"):
        print(f"  {tool}: {'yes' if shutil.which(tool) else 'MISSING'}")
    print("next:  auto schedule sync --dry-run")


# ---------- schedule sync ----------------------------------------------------
def cmd_schedule(args):
    if args.action != "sync":
        sys.exit("usage: auto schedule sync [--dry-run]")
    mach = current_machine()
    osname = this_os()
    due = [j for j in load_jobs()
           if (j.get("schedule") or {}).get("enabled") and (j.get("schedule") or {}).get("cron")
           and job_runs_here(j, mach)]
    print(f"# {len(due)} scheduled job(s) for this machine ({osname})")
    if osname in ("linux",):
        _sync_cron(due, args.dry_run)
    elif osname == "macos":
        _sync_launchd(due, args.dry_run)
    elif osname == "windows":
        _sync_windows(due, args.dry_run)

def _auto_cmd(job_id: str) -> str:
    return f'"{sys.executable}" "{Path(__file__).resolve()}" run {job_id}'

def _sync_cron(due, dry):
    marker_a, marker_b = "# >>> automation-monorepo >>>", "# <<< automation-monorepo <<<"
    block = [marker_a]
    for j in due:
        block.append(f"{j['schedule']['cron']} {_auto_cmd(j['id'])}  # {j['id']}")
    block.append(marker_b)
    block_txt = "\n".join(block)
    if dry:
        print("would install this managed crontab block:\n" + block_txt); return
    try:
        cur = subprocess.run(["crontab", "-l"], capture_output=True, text=True).stdout
    except Exception:
        cur = ""
    cur = re.sub(re.escape(marker_a) + r".*?" + re.escape(marker_b), "", cur, flags=re.S).strip()
    new = (cur + "\n\n" + block_txt + "\n").lstrip()
    subprocess.run(["crontab", "-"], input=new, text=True)
    print("crontab updated.")

def _sync_launchd(due, dry):
    GEN.mkdir(parents=True, exist_ok=True)
    for j in due:
        label = f"com.automation.{j['id']}"
        mins, hrs, *_ = (j["schedule"]["cron"].split() + ["*", "*"])[:2]
        plist = textwrap.dedent(f"""\
        <?xml version="1.0" encoding="UTF-8"?>
        <!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
        <plist version="1.0"><dict>
          <key>Label</key><string>{label}</string>
          <key>ProgramArguments</key><array>
            <string>{sys.executable}</string><string>{Path(__file__).resolve()}</string>
            <string>run</string><string>{j['id']}</string></array>
          <key>StartCalendarInterval</key><dict>
            <key>Hour</key><integer>{hrs if hrs.isdigit() else 0}</integer>
            <key>Minute</key><integer>{mins if mins.isdigit() else 0}</integer></dict>
        </dict></plist>""")
        out = GEN / f"{label}.plist"
        out.write_text(plist)
        print(f"wrote {out.relative_to(REPO)}")
    if not dry:
        print("load with:  cp schedules/generated/*.plist ~/Library/LaunchAgents/ && "
              "for p in ~/Library/LaunchAgents/com.automation.*; do launchctl load \"$p\"; done")

def _sync_windows(due, dry):
    GEN.mkdir(parents=True, exist_ok=True)
    lines = ["@echo off", "REM Run this .bat as your user to (re)register scheduled tasks."]
    for j in due:
        mins, hrs, *_ = (j["schedule"]["cron"].split() + ["0", "0"])[:2]
        hh = hrs if hrs.isdigit() else "0"; mm = mins if mins.isdigit() else "0"
        cmd = _auto_cmd(j["id"])
        lines.append(f'schtasks /Create /F /TN "automation\\{j["id"]}" /SC DAILY '
                     f'/ST {int(hh):02d}:{int(mm):02d} /TR {cmd}')
    out = GEN / "install-tasks.bat"
    out.write_text("\r\n".join(lines) + "\r\n")
    print(f"wrote {out.relative_to(REPO)}" + ("" if dry else "  — run it to register tasks"))


# ---------- arg parsing ------------------------------------------------------
def main():
    p = argparse.ArgumentParser(prog="auto", description="automation-monorepo CLI")
    sub = p.add_subparsers(dest="cmd", required=True)
    sub.add_parser("list").add_argument("--json", action="store_true")
    sp = sub.add_parser("search"); sp.add_argument("term")
    sp = sub.add_parser("run"); sp.add_argument("id"); sp.add_argument("extra", nargs="*")
    sub.add_parser("new")
    sub.add_parser("catalog")
    sp = sub.add_parser("log"); sp.add_argument("message")
    sub.add_parser("doctor")
    sub.add_parser("bootstrap")
    sp = sub.add_parser("schedule"); sp.add_argument("action"); sp.add_argument("--dry-run", action="store_true")
    args = p.parse_args()
    {"list": cmd_list, "search": cmd_search, "run": cmd_run, "new": cmd_new,
     "catalog": cmd_catalog, "log": cmd_log, "doctor": cmd_doctor,
     "bootstrap": cmd_bootstrap, "schedule": cmd_schedule}[args.cmd](args)

if __name__ == "__main__":
    main()
