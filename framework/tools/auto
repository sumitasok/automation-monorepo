#!/usr/bin/env python3
"""auto — the automation-framework CLI (pack-aware).

Every script is a "job": a folder with a manifest.yaml. Jobs live in *packs*;
a *workspace* mounts packs via packs.yaml. This tool discovers jobs across all
mounted packs and does everything else: run, scaffold, schedule, document,
health-check, and enforce the private/shared/public visibility rules.

Usage:
  auto list [--json] [--visibility private|shared|public]
  auto packs
  auto search <term>
  auto run <id> [--ai <name>] [-- extra args]
  auto new
  auto catalog                 # workspace catalog (all packs)
  auto share [<pack>]          # write a shareable catalog of a pack's non-private jobs
  auto schedule sync [--dry-run]
  auto log "<message>"
  auto doctor                  # validate manifests + enforce visibility rules
  auto bootstrap
  auto serve [--port N]        # local dashboard: packs, config status, jobs, command help
"""
from __future__ import annotations
import argparse, html, os, platform, re, socket, subprocess, sys, textwrap, datetime, shutil
from pathlib import Path

try:
    import yaml
except ImportError:
    sys.exit("PyYAML is required.  pip install pyyaml  (or: pip install --break-system-packages pyyaml)")

FRAMEWORK = Path(__file__).resolve().parent.parent          # .../framework
VISIBILITIES = ("private", "shared", "public")


# ---------- workspace & packs ------------------------------------------------
def find_workspace() -> Path:
    """Workspace root = nearest ancestor containing packs.yaml."""
    env = os.environ.get("AUTO_WORKSPACE")
    start = Path(env) if env else Path.cwd()
    for d in [start, *start.parents]:
        if (d / "packs.yaml").exists():
            return d
    return FRAMEWORK.parent   # fallback: framework usually sits inside the workspace

WS = find_workspace()
DATA = WS / "data"
GEN = WS / "schedules" / "generated"
WORKLOG = WS / "docs" / "worklog"

def load_yaml(p: Path) -> dict:
    with open(p) as f:
        return yaml.safe_load(f) or {}

def load_packs() -> list[dict]:
    pf = WS / "packs.yaml"
    if not pf.exists():
        return []
    packs = []
    for p in load_yaml(pf).get("packs", []):
        p["_path"] = WS / p["path"]
        packs.append(p)
    return packs

def pack_default_vis(pack: dict) -> str:
    pj = pack["_path"] / "pack.yaml"          # pack.yaml wins over the registry
    if pj.exists():
        v = load_yaml(pj).get("default_visibility")
        if v:
            return v
    return pack.get("default_visibility", "private")

def pack_config_dir(pack_name: str) -> Path:
    """Workspace-local, git-ignored dir holding a pack's real config + secrets."""
    return WS / "config" / pack_name

def load_pack_config(pack: dict):
    """Return (env_dict, files_list, config_dir) for a pack.

    Contract: the pack ships `config.sample.yaml` at its root declaring the env
    keys it reads and the secret files it needs. The workspace overrides values
    in `config/<pack>/config.yaml` (git-ignored). Env precedence, low→high:
    sample defaults < workspace override < the ambient shell environment.
    """
    sample = pack["_path"] / "config.sample.yaml"
    override = pack_config_dir(pack["name"]) / "config.yaml"
    env, files = {}, []
    if sample.exists():
        s = load_yaml(sample)
        env.update({str(k): "" if v is None else str(v) for k, v in (s.get("env") or {}).items()})
        files = list(s.get("files") or [])
    if override.exists():
        o = load_yaml(override)
        env.update({str(k): "" if v is None else str(v) for k, v in (o.get("env") or {}).items()})
    return env, files, pack_config_dir(pack["name"])


# ---------- AI provider profiles (ADR 0015) ----------------------------------
def ai_profile_dir() -> Path:
    """Workspace-local, git-ignored dir holding named AI provider profiles,
    shared by every pack — see config/ai/README.md."""
    return WS / "config" / "ai"

def load_ai_profile(name: str) -> dict:
    """Load and validate config/ai/<name>.yaml: provider, api_key (required),
    optional model / api_base. Exits with a clear message on any problem —
    an explicit `--ai <name>` should never fail silently or fall through to
    some other credential source."""
    path = ai_profile_dir() / f"{name}.yaml"
    if not path.exists():
        sys.exit(f"AI profile '{name}' not found at {path.relative_to(WS)}\n"
                  f"  copy an example: cp config/ai/deepseek.example.yaml config/ai/{name}.yaml")
    p = load_yaml(path)
    provider = str(p.get("provider") or "").strip().lower()
    api_key = str(p.get("api_key") or "")
    if not provider:
        sys.exit(f"AI profile '{name}' ({path.relative_to(WS)}): missing required field 'provider'")
    if provider not in ("deepseek", "claude", "anthropic"):
        sys.exit(f"AI profile '{name}' ({path.relative_to(WS)}): unsupported provider '{provider}' "
                  f"(want \"deepseek\" or \"claude\")")
    if not api_key:
        sys.exit(f"AI profile '{name}' ({path.relative_to(WS)}): missing required field 'api_key'")
    return {"provider": provider, "api_key": api_key,
            "model": str(p.get("model") or ""), "api_base": str(p.get("api_base") or "")}

def ai_profile_env(name: str) -> dict:
    """Map a named AI profile to the env vars provider clients already read
    (DEEPSEEK_API_KEY/DEEPSEEK_MODEL/DEEPSEEK_API_BASE, or the ANTHROPIC_*
    equivalents), plus AI_PROVIDER. Any pack whose code already reads those
    (as packs/gmail did before ADR 0015 existed) picks this up with zero
    per-pack code — that's the point: the profile lives once, `auto run`
    injects it into whichever job asked for it via --ai <name>."""
    prof = load_ai_profile(name)
    provider = prof["provider"]
    env = {"AI_PROVIDER": "claude" if provider in ("claude", "anthropic") else "deepseek"}
    if provider == "deepseek":
        env["DEEPSEEK_API_KEY"] = prof["api_key"]
        if prof["model"]:
            env["DEEPSEEK_MODEL"] = prof["model"]
        if prof["api_base"]:
            env["DEEPSEEK_API_BASE"] = prof["api_base"]
    else:  # claude / anthropic
        env["ANTHROPIC_API_KEY"] = prof["api_key"]
        if prof["model"]:
            env["ANTHROPIC_MODEL"] = prof["model"]
        if prof["api_base"]:
            env["ANTHROPIC_API_BASE"] = prof["api_base"]
    return env


# ---------- jobs -------------------------------------------------------------
def load_jobs() -> list[dict]:
    jobs = []
    for pack in load_packs():
        jroot = pack["_path"] / "jobs"
        if not jroot.exists():
            continue
        dvis = pack_default_vis(pack)
        for mp in sorted(jroot.rglob("manifest.yaml")):
            try:
                m = load_yaml(mp)
            except Exception as e:
                print(f"! bad manifest {mp}: {e}", file=sys.stderr); continue
            m["_dir"] = mp.parent
            m["_pack"] = pack["name"]
            m["_packpath"] = pack["_path"]
            m["_visibility"] = m.get("visibility") or dvis
            jobs.append(m)
    return jobs

def get_job(job_id: str) -> dict:
    for j in load_jobs():
        if j.get("id") == job_id:
            return j
    sys.exit(f"no job with id '{job_id}'  (try: auto list)")

def this_os() -> str:
    s = platform.system().lower()
    return {"darwin": "macos", "windows": "windows"}.get(s, "linux")

def machines() -> list[dict]:
    mf = WS / "machines.yaml"
    return load_yaml(mf).get("machines", []) if mf.exists() else []

def current_machine() -> dict | None:
    host = os.environ.get("AUTO_MACHINE_ID") or socket.gethostname()
    for m in machines():
        if host in (m.get("id"), m.get("hostname")):
            return m
    return None

def job_runs_here(j: dict, mach: dict | None) -> bool:
    ro = j.get("runs_on", {}) or {}
    if this_os() not in ro.get("os", ["macos", "linux", "windows"]):
        return False
    want = ro.get("machines", ["any"])
    return "any" in want or bool(mach and mach.get("id") in want)


# ---------- commands ---------------------------------------------------------
def cmd_packs(args):
    ps = load_packs()
    if not ps:
        print("no packs registered — see packs.yaml"); return
    for p in ps:
        exists = "ok" if p["_path"].exists() else "MISSING"
        print(f"{p['name']:<12} vis:{pack_default_vis(p):<7} writable:{str(p.get('writable', False)):<5} {exists}  {p['path']}")

def cmd_list(args):
    jobs = load_jobs()
    if args.visibility:
        jobs = [j for j in jobs if j["_visibility"] == args.visibility]
    if getattr(args, "json", False):
        import json
        print(json.dumps([{k: v for k, v in j.items() if not k.startswith("_")} | {"pack": j["_pack"], "visibility": j["_visibility"]} for j in jobs], indent=2, default=str))
        return
    if not jobs:
        print("no jobs yet — create one with:  auto new"); return
    w = max((len(j.get("id", "")) for j in jobs), default=2)
    for j in sorted(jobs, key=lambda x: (x["_pack"], x.get("id", ""))):
        sch = j.get("schedule") or {}
        when = sch.get("cron") if sch.get("enabled") else "(manual)"
        print(f"{j.get('id',''):<{w}}  {j['_pack']:<8} {j['_visibility']:<7} {j.get('language',''):<6} {when or '(none)':<12} {j.get('name','')}")

def cmd_search(args):
    t = args.term.lower()
    for j in load_jobs():
        hay = " ".join(str(j.get(k, "")) for k in ("id", "name", "description", "category")) + " " + " ".join(j.get("tags", []))
        if t in hay.lower():
            print(f"{j.get('id')}  [{j['_pack']}/{j['_visibility']}]  —  {j.get('name')}")

def _link_pack_files(files, cfg_dir: Path, workdir: Path):
    """Make a pack's declared secret files available in the workdir via symlink,
    so file-based apps (that read e.g. ./credentials.json) find them. The real
    files live in the git-ignored workspace config dir; the symlink also lets the
    app WRITE through (e.g. token.json) so state persists across re-clones."""
    for name in files:
        target = cfg_dir / name
        link = workdir / name
        try:
            if link.is_symlink():
                link.unlink()
            elif link.exists():
                print(f"   (config) {name} already a real file in workdir — leaving it"); continue
            link.symlink_to(target)   # may be dangling (e.g. token.json created on first run)
        except OSError as e:
            print(f"   (config) could not link {name}: {e}")

def cmd_run(args):
    j = get_job(args.id)
    pack = next(p for p in load_packs() if p["name"] == j["_pack"])
    cfg_env, cfg_files, cfg_dir = load_pack_config(pack)
    ai_env = ai_profile_env(args.ai) if getattr(args, "ai", "") else {}
    # env precedence: pack sample defaults < workspace override < ambient shell env
    # < --ai <name> (ADR 0015 — the most specific, explicitly-named choice wins)
    env = {**cfg_env, **os.environ, **ai_env,
           "AUTO_DATA_DIR": str(DATA), "AUTO_WORKSPACE": str(WS),
           "AUTO_JOB_ID": j["id"], "AUTO_PACK": j["_pack"],
           "AUTO_PACK_CONFIG_DIR": str(cfg_dir)}
    if ai_env:
        print(f"   (ai) profile '{args.ai}' loaded — provider: {ai_env.get('AI_PROVIDER')}")
    timeout = (j.get("runtime") or {}).get("timeout_seconds", 600)
    # workdir defaults to the job folder; app-backed jobs set it relative to the pack root
    workdir = j["_dir"]
    if j.get("workdir"):
        workdir = (j["_packpath"] / j["workdir"]).resolve()
    if cfg_files and cfg_dir.exists():
        _link_pack_files(cfg_files, cfg_dir, workdir)
    if j.get("exec"):
        # app-backed job: run an explicit shell command in workdir (e.g. "go run . discover")
        cmd = j["exec"] + (" " + " ".join(args.extra) if args.extra else "")
        shell = True; show = cmd
    else:
        # script job: run a single entrypoint file with the language runner
        entry = j["_dir"] / j.get("entrypoint", "")
        if not entry.exists():
            sys.exit(f"entrypoint not found: {entry}")
        runner = {"python": [sys.executable], "node": ["node"], "bash": ["bash"], "go": ["go", "run"]}.get(j.get("language", "bash"), ["bash"])
        cmd = runner + [str(entry)] + args.extra
        shell = False; show = " ".join(cmd)
    start = datetime.datetime.now()
    print(f">> running {j['id']} [{j['_pack']}] in {workdir}: {show}")
    try:
        rc = subprocess.run(cmd, env=env, timeout=timeout, cwd=str(workdir), shell=shell).returncode
    except subprocess.TimeoutExpired:
        rc = 124; print(f"!! timed out after {timeout}s")
    dur = (datetime.datetime.now() - start).total_seconds()
    _record_run(j["id"], rc, dur)
    print(f"<< {j['id']} exited {rc} in {dur:.1f}s")
    sys.exit(rc)

def _record_run(job_id, rc, dur):
    try:
        import sqlite3
        db = DATA / "state" / "runs.sqlite"; db.parent.mkdir(parents=True, exist_ok=True)
        c = sqlite3.connect(db)
        c.execute("CREATE TABLE IF NOT EXISTS runs(ts TEXT, job TEXT, host TEXT, rc INTEGER, dur REAL)")
        c.execute("INSERT INTO runs VALUES (?,?,?,?,?)", (datetime.datetime.utcnow().isoformat(), job_id, socket.gethostname(), rc, dur))
        c.commit(); c.close()
    except Exception as e:
        print(f"(run history not recorded: {e})", file=sys.stderr)

def cmd_new(args):
    packs = [p for p in load_packs() if p.get("writable")]
    if not packs:
        sys.exit("no writable packs in packs.yaml")
    print("Which pack?  " + ", ".join(f"{i}:{p['name']}({pack_default_vis(p)})" for i, p in enumerate(packs)))
    pack = packs[int((input("  pack [0]: ").strip() or "0"))]
    jid = input("  id (kebab-case): ").strip()
    if not re.fullmatch(r"[a-z0-9][a-z0-9-]*", jid or ""):
        sys.exit("id must be kebab-case")
    if any(j["id"] == jid for j in load_jobs()):
        sys.exit(f"id '{jid}' already exists in another pack")
    cat = input("  category [uncategorized]: ").strip() or "uncategorized"
    name = input("  name: ").strip() or jid
    lang = input("  language [python/bash/node/go]: ").strip() or "python"
    dest = pack["_path"] / "jobs" / cat / jid
    if dest.exists():
        sys.exit(f"{dest} already exists")
    dest.mkdir(parents=True)
    ext = {"python": "py", "bash": "sh", "node": "js", "go": "go"}.get(lang, "sh")
    entry = f"main.{ext}"
    (dest / entry).write_text("#!/usr/bin/env bash\nset -euo pipefail\necho hi\n" if lang == "bash" else f"# {name}\n")
    m = load_yaml(FRAMEWORK / "template" / "manifest.yaml")
    m.update({"id": jid, "name": name, "category": cat, "language": lang,
              "entrypoint": entry, "visibility": pack_default_vis(pack)})
    with open(dest / "manifest.yaml", "w") as f:
        yaml.safe_dump(m, f, sort_keys=False)
    shutil.copy(FRAMEWORK / "template" / "README.md", dest / "README.md")
    print(f"created {dest.relative_to(WS)}\n  edit manifest + {entry}, then:  ./auto run {jid}")

def _catalog_rows(jobs):
    rows = ["| id | name | pack | visibility | lang | schedule | machines |",
            "|----|------|------|-----------|------|----------|----------|"]
    for j in sorted(jobs, key=lambda x: (x["_pack"], x.get("category", ""), x.get("id", ""))):
        sch = j.get("schedule") or {}
        when = f"`{sch.get('cron')}`" if sch.get("enabled") and sch.get("cron") else "manual"
        mc = ", ".join((j.get("runs_on") or {}).get("machines", ["any"]))
        rows.append(f"| {j.get('id')} | {j.get('name','')} | {j['_pack']} | {j['_visibility']} | {j.get('language','')} | {when} | {mc} |")
    return rows

def cmd_catalog(args):
    jobs = load_jobs()
    out = ["# Catalog (workspace)", "", "_Auto-generated by `auto catalog`._", "",
           f"{len(jobs)} job(s) across {len(load_packs())} pack(s).", ""] + _catalog_rows(jobs)
    (WS / "CATALOG.md").write_text("\n".join(out) + "\n")
    print(f"wrote CATALOG.md ({len(jobs)} jobs)")

def cmd_share(args):
    """Write a shareable catalog of a pack containing only non-private jobs."""
    name = args.pack or "shared"
    pack = next((p for p in load_packs() if p["name"] == name), None)
    if not pack:
        sys.exit(f"no pack '{name}'")
    jobs = [j for j in load_jobs() if j["_pack"] == name and j["_visibility"] != "private"]
    out = [f"# Shareable catalog — pack '{name}'", "",
           "_Only non-private jobs. Generated by `auto share`._", "",
           f"{len(jobs)} shareable job(s).", ""] + _catalog_rows(jobs)
    dest = pack["_path"] / "CATALOG.md"
    dest.write_text("\n".join(out) + "\n")
    print(f"wrote {dest.relative_to(WS)} ({len(jobs)} shareable jobs)")

def cmd_log(args):
    WORKLOG.mkdir(parents=True, exist_ok=True)
    today = datetime.date.today().isoformat()
    f = WORKLOG / f"{today}.md"
    if not f.exists():
        f.write_text(f"# Worklog — {today}\n\n")
    with open(f, "a") as fh:
        fh.write(f"- {datetime.datetime.now():%H:%M} — {args.message}\n")
    print(f"logged to {f.relative_to(WS)}")

def cmd_doctor(args):
    ok = True
    ids = {}
    packs = load_packs()
    for pack in packs:
        if not pack["_path"].exists():
            print(f"FAIL pack '{pack['name']}' path missing: {pack['path']}"); ok = False
    for j in load_jobs():
        mp = j["_dir"] / "manifest.yaml"
        for field in ("id", "name", "language"):
            if not j.get(field):
                print(f"FAIL {mp}: missing '{field}'"); ok = False
        # a job runs EITHER a single entrypoint file OR an explicit exec command
        if not j.get("entrypoint") and not j.get("exec"):
            print(f"FAIL {mp}: needs either 'entrypoint' or 'exec'"); ok = False
        jid = j.get("id")
        if jid in ids:
            print(f"FAIL duplicate id '{jid}' ({j['_pack']} and {ids[jid]})"); ok = False
        ids[jid] = j["_pack"]
        if j.get("entrypoint") and not j.get("exec") and not (j["_dir"] / j["entrypoint"]).exists():
            print(f"FAIL {jid}: entrypoint missing"); ok = False
        if j.get("workdir"):
            wd = (j["_packpath"] / j["workdir"]).resolve()
            if not wd.exists():
                print(f"WARN {jid}: workdir not present ({j['workdir']}) — ok if pack is an unmounted submodule")
        vis = j["_visibility"]
        if vis not in VISIBILITIES:
            print(f"FAIL {jid}: invalid visibility '{vis}'"); ok = False; continue
        pack = next(p for p in packs if p["name"] == j["_pack"])
        if vis == "private" and pack_default_vis(pack) != "private":
            print(f"FAIL {jid}: private job in non-private pack '{j['_pack']}' — would leak on share"); ok = False
    print("OK — all manifests valid, no visibility leaks" if ok else "doctor found problems")
    sys.exit(0 if ok else 1)

def cmd_config(args):
    packs = load_packs()
    pack = next((p for p in packs if p["name"] == args.pack), None)
    if not pack:
        sys.exit(f"no pack '{args.pack}'  (see: auto packs)")
    sample = pack["_path"] / "config.sample.yaml"
    cfg_dir = pack_config_dir(pack["name"])
    override = cfg_dir / "config.yaml"
    env, files, _ = load_pack_config(pack)
    if args.action == "init":
        cfg_dir.mkdir(parents=True, exist_ok=True)
        if not sample.exists():
            print(f"pack '{args.pack}' ships no config.sample.yaml — nothing to init"); return
        if override.exists():
            print(f"{override.relative_to(WS)} already exists — leaving it")
        else:
            shutil.copy(sample, override)
            print(f"created {override.relative_to(WS)}  (git-ignored) — fill in real values")
        if files:
            print("place these secret files in " + str(cfg_dir.relative_to(WS)) + ":  " + ", ".join(files))
        return
    # status (default)
    print(f"pack '{args.pack}' config")
    print(f"  sample:   {sample.relative_to(pack['_path'].parent) if sample.exists() else '(none shipped)'}")
    print(f"  override: {override.relative_to(WS) if override.exists() else '(not created — run: auto config init ' + args.pack + ')'}")
    print(f"  dir:      {cfg_dir.relative_to(WS)}")
    for k, v in env.items():
        set_by = "shell" if os.environ.get(k) else ("override/sample" if v else "MISSING")
        print(f"  env {k}: {'set('+set_by+')' if (v or os.environ.get(k)) else 'MISSING'}")
    for f in files:
        present = (cfg_dir / f).exists()
        print(f"  file {f}: {'present' if present else 'MISSING — add to ' + str(cfg_dir.relative_to(WS))}")

# ---------- serve (local dashboard) ------------------------------------------
def _make_targets():
    """(file, target, help) for every `target: ... ## help` line in every Makefile in the workspace."""
    rows = []
    for mf in sorted(WS.rglob("Makefile")):
        if any(part in (".git", "node_modules") for part in mf.parts):
            continue
        try:
            text = mf.read_text()
        except Exception:
            continue
        for line in text.splitlines():
            m = re.match(r'^([a-zA-Z0-9_-]+):.*?##\s?(.*)$', line)
            if m:
                rows.append((str(mf.relative_to(WS)), m.group(1), m.group(2)))
    return rows

def _config_status(pack):
    env, files, cfg_dir = load_pack_config(pack)
    env_rows = [(k, "shell" if os.environ.get(k) else ("override/sample" if v else "MISSING")) for k, v in env.items()]
    file_rows = [(f, (cfg_dir / f).exists()) for f in files]
    return env_rows, file_rows

def _dashboard_html():
    packs = load_packs()
    jobs = load_jobs()
    mach = current_machine()

    pack_blocks = []
    for p in packs:
        exists = "ok" if p["_path"].exists() else "MISSING"
        env_rows, file_rows = _config_status(p)
        env_html = "".join(
            f"<tr><td>{html.escape(k)}</td><td class=\"{'ok' if v != 'MISSING' else 'bad'}\">{v}</td></tr>"
            for k, v in env_rows
        ) or "<tr><td colspan=2><em>none declared</em></td></tr>"
        file_html = "".join(
            f"<tr><td>{html.escape(f)}</td><td class=\"{'ok' if present else 'bad'}\">{'present' if present else 'MISSING'}</td></tr>"
            for f, present in file_rows
        ) or "<tr><td colspan=2><em>none declared</em></td></tr>"
        pack_blocks.append(f"""
        <div class="card">
          <h3>{html.escape(p['name'])} <span class="tag">{pack_default_vis(p)}</span>
              <span class="tag">{'writable' if p.get('writable') else 'read-only'}</span>
              <span class="{'ok' if exists == 'ok' else 'bad'}">{exists}</span></h3>
          <p class="path">{html.escape(p['path'])}</p>
          <table><tr><th colspan=2>env</th></tr>{env_html}</table>
          <table><tr><th colspan=2>files</th></tr>{file_html}</table>
        </div>""")

    def sched_of(j):
        sch = j.get("schedule") or {}
        return sch.get("cron") if sch.get("enabled") and sch.get("cron") else "(manual)"

    job_rows = "".join(
        f"<tr><td>{html.escape(j.get('id',''))}</td><td>{html.escape(j['_pack'])}</td>"
        f"<td>{html.escape(j['_visibility'])}</td><td>{html.escape(j.get('language',''))}</td>"
        f"<td>{html.escape(sched_of(j))}</td><td>{html.escape(j.get('name',''))}</td></tr>"
        for j in sorted(jobs, key=lambda x: (x["_pack"], x.get("id", "")))
    ) or "<tr><td colspan=6><em>no jobs yet — auto new</em></td></tr>"

    cmd_rows = "".join(
        f"<tr><td>{html.escape(f)}</td><td><code>make {html.escape(t)}</code></td><td>{html.escape(h)}</td></tr>"
