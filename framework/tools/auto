def cmd_serve(args):
    from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer

    class Handler(BaseHTTPRequestHandler):
        def do_GET(self):
            body = _dashboard_html().encode("utf-8")
            self.send_response(200)
            self.send_header("Content-Type", "text/html; charset=utf-8")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)

        def log_message(self, fmt, *a):
            pass  # quiet — read-only, localhost-only dashboard; see ADR 0012

    httpd = ThreadingHTTPServer(("127.0.0.1", args.port), Handler)
    print(f"serving workspace dashboard on http://127.0.0.1:{args.port}  (Ctrl+C to stop)")
    try:
        httpd.serve_forever()
    except KeyboardInterrupt:
        print("\nstopped")
    finally:
        httpd.server_close()

def cmd_bootstrap(args):
    print(f"workspace = {WS}")
    print(f"os = {this_os()}, hostname = {socket.gethostname()}")
    m = current_machine()
    print(f"registered as: {m['id']}" if m else "NOT in machines.yaml — add this host.")
    if shutil.which("git"):
        subprocess.run(["git", "-C", str(WS), "submodule", "update", "--init", "--recursive"])
        subprocess.run(["git", "lfs", "install"], cwd=WS)
    for tool in ("python3", "node", "go", "sqlite3"):
        print(f"  {tool}: {'yes' if shutil.which(tool) else 'MISSING'}")
    print("next:  ./auto schedule sync --dry-run")


# ---------- schedule sync ----------------------------------------------------
def cmd_schedule(args):
    if args.action != "sync":
        sys.exit("usage: auto schedule sync [--dry-run]")
    mach = current_machine(); osname = this_os()
    due = [j for j in load_jobs()
           if (j.get("schedule") or {}).get("enabled") and (j.get("schedule") or {}).get("cron")
           and job_runs_here(j, mach)]
    print(f"# {len(due)} scheduled job(s) for this machine ({osname})")
    {"linux": _sync_cron, "macos": _sync_launchd, "windows": _sync_windows}[osname](due, args.dry_run)

def _auto_cmd(job_id):
    return f'"{sys.executable}" "{Path(__file__).resolve()}" run {job_id}'

def _sync_cron(due, dry):
    a, b = "# >>> automation >>>", "# <<< automation <<<"
    block = "\n".join([a, *[f"{j['schedule']['cron']} {_auto_cmd(j['id'])}  # {j['id']}" for j in due], b])
    if dry:
        print("would install:\n" + block); return
    try:
        cur = subprocess.run(["crontab", "-l"], capture_output=True, text=True).stdout
    except Exception:
        cur = ""
    cur = re.sub(re.escape(a) + r".*?" + re.escape(b), "", cur, flags=re.S).strip()
    subprocess.run(["crontab", "-"], input=(cur + "\n\n" + block + "\n").lstrip(), text=True)
    print("crontab updated.")

def _sync_launchd(due, dry):
    GEN.mkdir(parents=True, exist_ok=True)
    for j in due:
        label = f"com.automation.{j['id']}"
        mins, hrs, *_ = (j["schedule"]["cron"].split() + ["*", "*"])[:2]
        (GEN / f"{label}.plist").write_text(textwrap.dedent(f"""\
        <?xml version="1.0" encoding="UTF-8"?>
        <!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
        <plist version="1.0"><dict>
          <key>Label</key><string>{label}</string>
          <key>ProgramArguments</key><array>
            <string>{sys.executable}</string><string>{Path(__file__).resolve()}</string>
            <string>run</string><string>{j['id']}</string></array>
          <key>StartCalendarInterval</key><dict>
            <key>Hour</key><integer>{hrs if hrs.isdigit() else 0}</integer>
            <key>Minute</key><integer>{mins if mins.isdigit() else 0}</integer></dict>
        </dict></plist>"""))
        print(f"wrote {(GEN / (label + '.plist')).relative_to(WS)}")
    if not dry:
        print("load:  cp schedules/generated/*.plist ~/Library/LaunchAgents/ && for p in ~/Library/LaunchAgents/com.automation.*; do launchctl load \"$p\"; done")

def _sync_windows(due, dry):
    GEN.mkdir(parents=True, exist_ok=True)
    lines = ["@echo off", "REM Run as your user to (re)register scheduled tasks."]
    for j in due:
        mins, hrs, *_ = (j["schedule"]["cron"].split() + ["0", "0"])[:2]
        hh = int(hrs) if hrs.isdigit() else 0; mm = int(mins) if mins.isdigit() else 0
        lines.append(f'schtasks /Create /F /TN "automation\\{j["id"]}" /SC DAILY /ST {hh:02d}:{mm:02d} /TR {_auto_cmd(j["id"])}')
    (GEN / "install-tasks.bat").write_text("\r\n".join(lines) + "\r\n")
    print(f"wrote {(GEN / 'install-tasks.bat').relative_to(WS)}" + ("" if dry else " — run it to register tasks"))


def _extract_ai_flag(argv: list[str]) -> tuple[list[str], str]:
    """Pull `--ai NAME` / `--ai=NAME` out of argv before argparse sees it
    (ADR 0015), so it never has to coexist with `run`'s own bare `--`
    separator inside argparse itself: a `nargs='*'` positional plus another
    named option on the same subparser has unreliable `--` handling across
    Python versions (verified broken on 3.10; fixed upstream in 3.13, but
    this script's shebang can't assume that). Returns (remaining argv, name),
    name == "" if --ai wasn't given."""
    out, ai, i = [], "", 0
    while i < len(argv):
        tok = argv[i]
        if tok == "--ai" and i + 1 < len(argv):
            ai = argv[i + 1]; i += 2; continue
        if tok.startswith("--ai="):
            ai = tok[len("--ai="):]; i += 1; continue
        out.append(tok); i += 1
    return out, ai

# ---------- arg parsing ------------------------------------------------------
def main():
    argv = sys.argv[1:]
    ai_name = ""
    if argv and argv[0] == "run":
        argv, ai_name = _extract_ai_flag(argv)

    p = argparse.ArgumentParser(prog="auto", description="automation-framework CLI")
    sub = p.add_subparsers(dest="cmd", required=True)
    lp = sub.add_parser("list"); lp.add_argument("--json", action="store_true"); lp.add_argument("--visibility", choices=VISIBILITIES)
    sub.add_parser("packs")
    sp = sub.add_parser("search"); sp.add_argument("term")
    rp = sub.add_parser("run"); rp.add_argument("id"); rp.add_argument("extra", nargs="*")
    sub.add_parser("new"); sub.add_parser("catalog"); sub.add_parser("doctor"); sub.add_parser("bootstrap")
    shp = sub.add_parser("share"); shp.add_argument("pack", nargs="?")
    lgp = sub.add_parser("log"); lgp.add_argument("message")
    scp = sub.add_parser("schedule"); scp.add_argument("action"); scp.add_argument("--dry-run", action="store_true")
    cfp = sub.add_parser("config"); cfp.add_argument("action", choices=["status", "init"], nargs="?", default="status"); cfp.add_argument("pack")
    svp = sub.add_parser("serve"); svp.add_argument("--port", type=int, default=4321)
    a = p.parse_args(argv)
    a.ai = ai_name  # only meaningful for cmd == "run" (ADR 0015)
    {"list": cmd_list, "packs": cmd_packs, "search": cmd_search, "run": cmd_run, "new": cmd_new,
     "catalog": cmd_catalog, "share": cmd_share, "log": cmd_log, "doctor": cmd_doctor,
     "bootstrap": cmd_bootstrap, "schedule": cmd_schedule, "config": cmd_config, "serve": cmd_serve}[a.cmd](a)

if __name__ == "__main__":
    main()
